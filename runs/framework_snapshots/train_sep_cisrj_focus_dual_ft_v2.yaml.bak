train_sep:
  seed: 20260304
  batch_size: 12
  num_workers: 0
  epochs_smoke: 3
  epochs_formal: 40
  lr: 0.0002
  weight_decay: 0.0001
  grad_clip: 5.0
  early_stop_patience: 12
  amp: false
  device: auto
  normalize_targets: true
  scheduler:
    type: plateau
    factor: 0.5
    patience: 2
    threshold: 0.0001
    cooldown: 0
    min_lr: 0.000001
  loss_sep:
    w_bg: 0.0
    w_sil: 0.05
    w_orth: 0.02
    w_bgtrue: 0.0
    w_bgenv: 0.0
    w_div: 0.02
